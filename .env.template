# AWS Configuration Template
# Copy this file to .env and fill in your values
# DO NOT commit .env to git (it's in .gitignore)

# ============================================
# AWS Credentials
# ============================================
# Get these from: AWS Console → IAM → Users → Security Credentials
AWS_ACCESS_KEY_ID=your_access_key_here
AWS_SECRET_ACCESS_KEY=your_secret_key_here
AWS_REGION=us-east-1

# ============================================
# S3 Configuration
# ============================================
# Use S3 for data/models (true for production, false for local)
USE_S3=false

# S3 bucket for ML artifacts (models, encoders)
S3_BUCKET=house-forecast

# S3 bucket for raw dataset (can be same as S3_BUCKET or different)
S3_DATA_BUCKET=house-forecast

# S3 key/path to raw dataset CSV file
S3_DATA_KEY=raw/housing_data.csv

# ============================================
# Local Development
# ============================================
# Path to local raw data file (used when USE_S3=false)
LOCAL_DATA_PATH=data/raw/HouseTS.csv

# Local directories
MODEL_DIR=models
DATA_DIR=data

# ============================================
# API Configuration
# ============================================
API_HOST=0.0.0.0
API_PORT=8000

# ============================================
# MLflow Configuration
# ============================================
MLFLOW_TRACKING_URI=sqlite:///mlflow.db
MLFLOW_EXPERIMENT_NAME=housing-price-prediction

