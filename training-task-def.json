{
  "family": "housing-training-task",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "2048",
  "memory": "4096",
  "executionRoleArn": "arn:aws:iam::261899902410:role/ecsTaskExecutionRole",
  "taskRoleArn": "arn:aws:iam::261899902410:role/ecsTaskRole",
  "containerDefinitions": [
    {
      "name": "training-container",
      "image": "261899902410.dkr.ecr.us-east-1.amazonaws.com/housing-training:latest",
      "essential": true,
      "environment": [
        {
          "name": "S3_BUCKET",
          "value": "house-forecast"
        },
        {
          "name": "AWS_REGION",
          "value": "us-east-1"
        },
        {
          "name": "USE_S3",
          "value": "true"
        },
        {
          "name": "MLFLOW_TRACKING_URI",
          "value": "sqlite:////tmp/mlflow.db"
        },
        {
          "name": "MLFLOW_ARTIFACT_ROOT",
          "value": "s3://house-forecast/mlflow/artifacts"
        }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/housing-training",
          "awslogs-region": "us-east-1",
          "awslogs-stream-prefix": "training",
          "awslogs-create-group": "true"
        }
      },
      "resourceRequirements": []
    }
  ]
}
